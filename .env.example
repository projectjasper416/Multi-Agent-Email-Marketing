# ─────────────────────────────────────────────────────────────────────
# AI Email Marketing Agent — environment variables
# Copy to .env for local dev. NEVER commit .env.
#
# Key separation is a security boundary, enforced in serverless.yml:
#   - Planning Lambda  gets ANTHROPIC_API_KEY  but NOT RESEND_API_KEY
#   - Delivery Lambda  gets RESEND_API_KEY      but NOT ANTHROPIC_API_KEY
# A compromise in planning can never send mail; delivery can never call Claude.
# ─────────────────────────────────────────────────────────────────────

# Customer's Supabase (the only shared resource with the customer's app)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # service role: bypasses RLS, treat as a prod DB password
SUPABASE_ANON_KEY=                  # public/anon key: onboarding web auth (sign-in, JWT verify) only
SUPABASE_DB_URL=                    # postgresql://... connection string for checkpointer + store

# LLM (planning Lambda only)
ANTHROPIC_API_KEY=

# Observability (both Lambdas)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-email-marketing-agent

# Email delivery (delivery Lambda only)
RESEND_API_KEY=

# Telegram approval gate
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                   # operator's personal chat id
TELEGRAM_WEBHOOK_SECRET=            # openssl rand -hex 32  (delivery Lambda only)

# Customer identity — namespaces everything in LangGraph Store
CUSTOMER_ID=
